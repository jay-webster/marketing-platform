DATABASE_URL=postgresql+asyncpg://myuser:mypassword@localhost:5432/dev_db
SECRET_KEY=change-me-to-a-random-32-char-string-for-dev
INITIAL_ADMIN_TOKEN=local-setup-token
APP_URL=http://localhost:8000

# SMTP — use a local mail catcher like Mailpit for dev
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

# Ingestion Pipeline (Epic 3)
# GCS bucket for transient source file storage during processing
GCS_BUCKET_NAME=marketing-ingestion-dev
# Number of concurrent queue worker coroutines (default: 5)
WORKER_CONCURRENCY=5
# Local dev only — not used on GKE (Workload Identity resolves automatically)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json

# Agentic Chat / RAG (Epic 4)
# OpenAI API key for text-embedding-3-small ($0.02/1M tokens)
OPENAI_API_KEY=sk-...
# Cosine similarity floor — raise to reduce noise, lower to increase recall (0.0–1.0)
KB_SIMILARITY_THRESHOLD=0.3
# Number of chunks returned per query
KB_RETRIEVAL_TOP_K=6
# Claude model used for chat generation
CHAT_MODEL=claude-opus-4-6
# Max tokens per chat response
CHAT_MAX_TOKENS=1024
# Number of concurrent KB indexing workers
KB_INDEX_CONCURRENCY=2
# Admin token for knowledge-base admin endpoints (X-Admin-Token header)
ADMIN_TOKEN=change-me-to-a-secure-random-string

# Optional — defaults shown
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
SESSION_INACTIVITY_HOURS=8
APP_VERSION=1.0.0
